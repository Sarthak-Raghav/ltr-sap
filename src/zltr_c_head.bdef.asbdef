projection;
strict ( 2 );
use draft;

define behavior for ZLTR_C_Head alias Head
{
  use create;
  use update;
  use delete;

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  use association _Content { create; with draft; }
}

define behavior for ZLTR_C_Content alias Content
{

  use update;
  use delete;

  use association _Header { with draft; }
}